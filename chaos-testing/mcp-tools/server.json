{
  "name": "foundatio-chaos",
  "description": "Chaos testing tools for Foundatio.RabbitMQ. Provides fault injection capabilities against Aspire-managed RabbitMQ containers including disk pressure, node failures, and cluster status monitoring.",
  "command": "bash",
  "args": ["chaos-testing/mcp-tools/run-chaos-tool.sh"],
  "tools": [
    "chaos-fill-disk.json",
    "chaos-clear-disk.json",
    "chaos-stop-node.json",
    "chaos-start-node.json",
    "chaos-check-alarm.json",
    "chaos-cluster-status.json"
  ],
  "prerequisites": [
    "Docker must be running",
    "Aspire AppHost must be started (run: dotnet run --project tests/Foundatio.RabbitMQ.AppHost)"
  ],
  "usage": {
    "start_apphost": "dotnet run --project tests/Foundatio.RabbitMQ.AppHost",
    "fill_disk": "./chaos-testing/mcp-tools/run-chaos-tool.sh fill_disk chaos-1",
    "clear_disk": "./chaos-testing/mcp-tools/run-chaos-tool.sh clear_disk chaos-1",
    "stop_node": "./chaos-testing/mcp-tools/run-chaos-tool.sh stop_node chaos-2",
    "start_node": "./chaos-testing/mcp-tools/run-chaos-tool.sh start_node chaos-2",
    "check_alarm": "./chaos-testing/mcp-tools/run-chaos-tool.sh check_alarm chaos-1",
    "cluster_status": "./chaos-testing/mcp-tools/run-chaos-tool.sh cluster_status chaos-1"
  }
}
