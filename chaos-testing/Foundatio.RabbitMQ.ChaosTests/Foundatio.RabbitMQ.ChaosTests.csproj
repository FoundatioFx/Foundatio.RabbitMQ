    <PackageReference Include="Aspire.Hosting.Testing" Version="13.3.4" />
    <PackageReference Include="Foundatio.Xunit.v3" Version="13.0.0-beta6.8" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../src/Foundatio.RabbitMQ/Foundatio.RabbitMQ.csproj" />
    <ProjectReference Include="../../tests/Foundatio.RabbitMQ.AppHost/Foundatio.RabbitMQ.AppHost.csproj" IsAspireProjectResource="false" />
  </ItemGroup>

</Project>
